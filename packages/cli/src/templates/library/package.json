{
  "name": "{{packageName}}",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "vitest",
    "type-check": "tsc --noEmit",
    "lint": "eslint ."
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "~5.8.3",
    "vitest": "^1.5.0"
  }
}
