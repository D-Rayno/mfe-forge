{
  "name": "mfe-forge",
  "version": "5.0.0",
  "description": "CLI for scaffolding and managing Micro Frontend architectures",
  "type": "module",
  "bin": {
    "mfe-forge": "./dist/bin/index.js",
    "mfe": "./dist/bin/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsup src/bin/index.ts src/index.ts --format esm --dts --clean --shims",
    "dev": "tsup src/bin/index.ts src/index.ts --format esm --dts --watch --shims",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "inquirer": "^9.2.0",
    "open": "^10.1.0",
    "ora": "^8.0.0",
    "fs-extra": "^11.2.0",
    "globby": "^14.0.0",
    "execa": "^8.0.0",
    "zod": "^3.22.0",
    "cosmiconfig": "^9.0.0",
    "mustache": "^4.2.0",
    "listr2": "^8.0.0",
    "portfinder": "^1.0.32",
    "node-fetch": "^3.3.2",
    "semver": "^7.6.0",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.7",
    "@types/mustache": "^4.2.5",
    "@types/semver": "^7.5.8",
    "tsup": "^8.0.0",
    "typescript": "~5.8.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "micro-frontend",
    "module-federation",
    "vite",
    "react",
    "cli",
    "monorepo",
    "mfe"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/D-Rayno/mfe-forge.git",
    "directory": "packages/cli"
  }
}
