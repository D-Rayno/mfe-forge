{
  "name": "@mfe-forge/design",
  "version": "1.0.0",
  "description": "Design system utilities for MFE Forge",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tokens": {
      "import": "./dist/tokens.js",
      "types": "./dist/tokens.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/tokens.ts --format esm --dts",
    "dev": "tsup src/index.ts src/tokens.ts --format esm --dts --watch",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "~5.8.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
