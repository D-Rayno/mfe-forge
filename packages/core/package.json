{
  "name": "@mfe-forge/core",
  "version": "1.0.0",
  "description": "Core runtime utilities for MFE Forge applications",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./error-boundary": {
      "import": "./dist/error-boundary.js",
      "types": "./dist/error-boundary.d.ts"
    },
    "./event-bus": {
      "import": "./dist/event-bus.js",
      "types": "./dist/event-bus.d.ts"
    },
    "./loader": {
      "import": "./dist/loader.js",
      "types": "./dist/loader.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/error-boundary.tsx src/event-bus.ts src/loader.tsx --format esm --dts --external react,react-dom",
    "dev": "tsup src/index.ts src/error-boundary.tsx src/event-bus.ts src/loader.tsx --format esm --dts --watch --external react,react-dom",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "~5.8.3",
    "@types/node": "^20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
