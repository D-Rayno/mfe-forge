{
  "name": "@mfe-forge/router",
  "version": "1.0.0",
  "description": "Routing coordination utilities for MFE Forge",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.tsx --format esm --dts --external react,react-dom,react-router-dom",
    "dev": "tsup src/index.tsx --format esm --dts --watch --external react,react-dom,react-router-dom",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "~5.8.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
